<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Brass: Lancashire - Game</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <a href="/lobby" class="nav-brand">Brass: Lancashire</a>
    <div class="nav-links">
      <a href="/lobby" class="nav-link">Lobby</a>
      <a href="/wiki" target="_blank" class="nav-link">Wiki</a>
      <span class="badge badge-version">v<%= appVersion %></span>
      <% if (user.username === 'xai') { %><button class="btn btn-sm" style="background:#5a1a1a;color:var(--accent);font-size:10px" onclick="AdminFix.open()">Fix</button><% } %>
      <a href="/account" class="nav-user"><%= user.username %></a>
    </div>
  </nav>

  <div class="game-container">
    <!-- Current turn indicator bar -->
    <div class="turn-indicator-bar" id="turn-indicator-bar"></div>

    <div class="game-main">
      <!-- Left panel: game info + players (collapsible) -->
      <div class="left-panel" id="left-panel">
        <div class="left-panel-toggle" onclick="GameUI.toggleLeftPanel()"><span id="left-panel-arrow">&#9664;</span></div>
        <div class="left-panel-content" id="left-panel-content">
          <div class="panel-section" id="game-info"></div>
          <div id="player-bar"></div>
          <div class="panel-section legend-panel">
            <div class="legend-row"><span class="legend-swatch" style="background:#f5f0ea"></span> <strong>M</strong> - Cotton Mill</div>
            <div class="legend-row"><span class="legend-swatch" style="background:#333"></span> <strong>C</strong> - Coal Mine</div>
            <div class="legend-row"><span class="legend-swatch" style="background:#d4740e"></span> <strong>I</strong> - Iron Works</div>
            <div class="legend-row"><span class="legend-swatch" style="background:#2196F3"></span> <strong>P</strong> - Port</div>
            <div class="legend-row"><span class="legend-swatch" style="background:#6d432a"></span> <strong>S</strong> - Shipyard</div>
          </div>
          <div class="panel-section turn-nav" id="turn-nav">
            <div style="display:flex;align-items:center;gap:6px;justify-content:center">
              <button class="btn nav-btn" onclick="GameUI.navFirst()" title="First">⏮</button>
              <button class="btn nav-btn" onclick="GameUI.navPrev()" title="Previous">◀</button>
              <span id="turn-nav-label" style="font-size:10px;min-width:60px;text-align:center">Live</span>
              <button class="btn nav-btn" onclick="GameUI.navNext()" title="Next">▶</button>
              <button class="btn nav-btn" onclick="GameUI.navLive()" title="Live">⏭</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Board -->
      <div class="board-container" id="board-container">
        <div class="board-controls">
          <div class="controls-row">
            <label>Map <input type="range" id="map-dim-slider" min="0" max="100" value="70" style="width:50px"
                   oninput="BoardRenderer.setMapOpacity(this.value)"></label>
            <label>Zoom <input type="range" id="zoom-slider" min="50" max="200" value="100" style="width:50px"
                   oninput="BoardRenderer.setZoom(this.value)"><span id="zoom-val">100</span>%</label>
            <label>Bot <input type="range" id="bot-delay-slider" min="1" max="5" value="2" style="width:40px"
                   oninput="GameUI.setBotDelay(this.value)"><span id="bot-delay-val">2</span>s</label>
          </div>
          <div class="controls-row">
            <label class="board-control-check"><input type="checkbox" id="minimal-toggle" onchange="BoardRenderer.toggleMinimal(this.checked)"> Minimal</label>
            <label class="board-control-check"><input type="checkbox" id="hide-names-toggle" onchange="BoardRenderer.toggleHideNames(this.checked)"> No names</label>
            <label class="board-control-check"><input type="checkbox" id="hide-icons-toggle" onchange="BoardRenderer.toggleHideIcons(this.checked)"> No icons</label>
            <span class="board-control-sep">|</span>
            <button class="btn btn-sm board-edit-btn" id="toggle-links-btn" onclick="BoardRenderer.toggleLinks()">Links</button>
            <button class="btn btn-sm board-edit-btn" id="edit-nodes-btn" onclick="BoardRenderer.toggleEditMode()">Move</button>
            <button class="btn btn-sm board-edit-btn" id="resize-nodes-btn" onclick="BoardRenderer.toggleResizeMode()">Resize</button>
            <button class="btn btn-sm" id="reset-nodes-btn" onclick="BoardRenderer.resetPositions()" style="display:none">Undo</button>
            <button class="btn btn-sm" id="like-xai-btn" onclick="BoardRenderer.loadXaiPositions()" style="display:none">Like Xai</button>
          </div>
        </div>
        <svg id="game-board" viewBox="0 0 600 520" xmlns="http://www.w3.org/2000/svg"></svg>
      </div>

      <!-- Right panel: actions + hand + mat (collapsible) -->
      <div class="right-panel" id="right-panel">
        <div class="right-panel-toggle" onclick="GameUI.toggleRightPanel()"><span id="right-panel-arrow">&#9654;</span></div>
        <div class="right-panel-content" id="right-panel-content">
          <div class="panel-section" id="action-panel"></div>
          <div class="panel-section" id="hand-panel"></div>
          <div class="panel-section" id="mat-panel"></div>
        </div>
      </div>
    </div>

    <!-- Floating hand (when detached) -->
    <div class="floating-hand" id="floating-hand">
      <div class="floating-hand-header">
        <span>Hand</span>
        <div class="hand-sort-btns">
          <button class="btn btn-sm" onclick="GameUI.sortHand('default')" title="Original order">&#8645;</button>
          <button class="btn btn-sm" onclick="GameUI.sortHand('type')" title="By type (LOC/IND)">T</button>
          <button class="btn btn-sm" onclick="GameUI.sortHand('alpha')" title="Alphabetical">Az</button>
          <button class="btn btn-sm" onclick="GameUI.sortHand('typeAlpha')" title="Type then alphabetical">T+Az</button>
        </div>
        <button class="btn btn-sm" onclick="GameUI.toggleDetachHand()">Dock</button>
      </div>
      <div class="floating-hand-cards" id="floating-hand-cards"></div>
    </div>

    <% if (user.username === 'xai') { %>
    <!-- Admin Fix Panel -->
    <div id="admin-fix-panel" style="display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
      background:var(--bg);border:2px solid var(--accent);border-radius:8px;padding:16px;z-index:100;
      min-width:320px;max-height:80vh;overflow-y:auto;font-size:12px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <h3 style="color:var(--accent);margin:0">Admin Fix Mode</h3>
        <button class="btn btn-sm" onclick="document.getElementById('admin-fix-panel').style.display='none'">Close</button>
      </div>
      <div id="admin-fix-content"></div>
    </div>
    <% } %>

    <!-- Collapsible log -->
    <div class="log-wrapper collapsed" id="log-wrapper">
      <div class="log-toggle" onclick="GameUI.toggleLog()">
        <span>Game Log <span id="log-arrow">&#9650;</span></span>
        <span class="log-filters" id="log-filters" onclick="event.stopPropagation()"></span>
        <label class="board-control-check" style="margin-left:4px" onclick="event.stopPropagation()"><input type="checkbox" id="log-timestamps" onchange="GameUI.logShowTimestamps=this.checked;GameUI.updateLog()"> Time</label>
      </div>
      <div class="log-panel" id="log-panel"></div>
    </div>

    <!-- Mobile turn nav (always visible, fixed above tabs) -->
    <div class="mobile-turn-nav" id="mobile-board-turn-nav">
      <button class="btn nav-btn" onclick="GameUI.navFirst()">⏮</button>
      <button class="btn nav-btn" onclick="GameUI.navPrev()">◀</button>
      <span id="mobile-board-turn-label" style="font-size:11px;min-width:50px;text-align:center">Live</span>
      <button class="btn nav-btn" onclick="GameUI.navNext()">▶</button>
      <button class="btn nav-btn" onclick="GameUI.navLive()">⏭</button>
    </div>

    <!-- Mobile tab bar -->
    <div class="mobile-tabs" id="mobile-tabs">
      <button class="mobile-tab" onclick="MobileUI.showTab('info')">
        <span class="mobile-tab-icon">&#9432;</span>Info
      </button>
      <button class="mobile-tab active" onclick="MobileUI.showTab('board')">
        <span class="mobile-tab-icon">&#9881;</span>Board
      </button>
      <button class="mobile-tab" onclick="MobileUI.showTab('hand')">
        <span class="mobile-tab-icon">&#9995;</span>Hand
      </button>
      <button class="mobile-tab" onclick="MobileUI.showTab('actions')">
        <span class="mobile-tab-icon">&#9889;</span>Actions
      </button>
      <button class="mobile-tab" onclick="MobileUI.showTab('log')">
        <span class="mobile-tab-icon">&#9776;</span>Log
      </button>
    </div>

    <!-- Mobile panel overlays -->
    <div class="mobile-panel-overlay" id="mobile-panel-hand">
      <div class="mobile-panel-close">
        <h3>Your Hand</h3>
        <button class="btn btn-sm" onclick="MobileUI.showTab('board')">Close</button>
      </div>
      <div id="mobile-hand-content"></div>
    </div>
    <div class="mobile-panel-overlay" id="mobile-panel-actions">
      <div class="mobile-panel-close">
        <h3>Actions</h3>
        <button class="btn btn-sm" onclick="MobileUI.showTab('board')">Close</button>
      </div>
      <div id="mobile-actions-content"></div>
    </div>
    <div class="mobile-panel-overlay" id="mobile-panel-info">
      <div class="mobile-panel-close">
        <h3>Game Info</h3>
        <button class="btn btn-sm" onclick="MobileUI.showTab('board')">Close</button>
      </div>
      <div id="mobile-info-content"></div>
    </div>
    <div class="mobile-panel-overlay" id="mobile-panel-log">
      <div class="mobile-panel-close">
        <h3>Game Log</h3>
        <button class="btn btn-sm" onclick="MobileUI.showTab('board')">Close</button>
      </div>
      <div class="mobile-turn-nav" id="mobile-log-turn-nav">
        <button class="btn nav-btn" onclick="GameUI.navFirst()">⏮</button>
        <button class="btn nav-btn" onclick="GameUI.navPrev()">◀</button>
        <span id="mobile-log-turn-label" style="font-size:11px;min-width:50px;text-align:center">Live</span>
        <button class="btn nav-btn" onclick="GameUI.navNext()">▶</button>
        <button class="btn nav-btn" onclick="GameUI.navLive()">⏭</button>
      </div>
      <div id="mobile-log-content"></div>
    </div>
  </div>

  <script>
    // Early mobile detection — must run before BoardRenderer.init()
    if (/Android|iPhone|iPad|iPod|webOS|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)
        || (window.innerWidth <= 768 && 'ontouchstart' in window)) {
      document.body.classList.add('is-mobile');
    }

    const GAME_ID = <%= game.id %>;
    const USER_ID = <%= userId %>;
    let gameState = <%- JSON.stringify(state) %>;
    let stateVersion = <%= version %>;
    const IS_MEMBER = <%= isMember %>;
    const CUSTOM_POSITIONS = <%- customPositions %>;
    const XAI_POSITIONS = <%- xaiPositions %>;
    const HISTORY_COUNT = <%= historyCount %>;
  </script>
  <script src="/js/board-data-client.js"></script>
  <script src="/js/industry-data-client.js"></script>
  <script src="/js/board-renderer.js"></script>
  <script src="/js/game-ui.js"></script>
  <script>
    // Mobile detection and UI
    const MobileUI = {
      isMobile: document.body.classList.contains('is-mobile'),
      currentTab: 'board',

      init() {
        if (this.isMobile) {
          // Force floating hand visible on mobile
          if (typeof GameUI !== 'undefined') {
            GameUI.handDetached = true;
          }
          const fh = document.getElementById('floating-hand');
          if (fh) fh.style.display = 'block';
          // Hide desktop log toggle (panel itself moves to mobile overlay)
          const logToggle = document.querySelector('.log-toggle');
          if (logToggle) logToggle.style.display = 'none';
          // Move real DOM panels into mobile overlays (live updates!)
          this.movePanelsToMobile();
        }
      },

      showTab(tab) {
        this.currentTab = tab;
        const tabOrder = ['info', 'board', 'hand', 'actions', 'log'];
        // Update tab bar
        document.querySelectorAll('.mobile-tab').forEach((t, i) => {
          t.classList.toggle('active', tabOrder[i] === tab);
        });
        // Hide all overlays
        document.querySelectorAll('.mobile-panel-overlay').forEach(p => p.classList.remove('active'));

        // Show/hide floating hand based on tab
        const fh = document.getElementById('floating-hand');
        if (fh) fh.style.display = (tab === 'board') ? 'block' : 'none';

        // Show/hide board
        const bc = document.getElementById('board-container');
        if (bc) bc.style.display = (tab === 'board') ? '' : 'none';

        if (tab === 'board') return;

        const panel = document.getElementById('mobile-panel-' + tab);
        if (panel) {
          panel.classList.add('active');
          this.populatePanel(tab);
        }
      },

      // Move actual DOM panels into mobile overlays (live, not cloned)
      _panelsMoved: false,

      movePanelsToMobile() {
        if (this._panelsMoved) return;
        this._panelsMoved = true;

        // Move action panel
        const actionPanel = document.getElementById('action-panel');
        const mobileActions = document.getElementById('mobile-actions-content');
        if (actionPanel && mobileActions) mobileActions.appendChild(actionPanel);

        // Move hand + mat panels
        const handPanel = document.getElementById('hand-panel');
        const matPanel = document.getElementById('mat-panel');
        const mobileHand = document.getElementById('mobile-hand-content');
        if (mobileHand && handPanel) mobileHand.appendChild(handPanel);
        if (mobileHand && matPanel) {
          const hr = document.createElement('hr');
          hr.style.cssText = 'border-color:#333;margin:12px 0';
          mobileHand.appendChild(hr);
          mobileHand.appendChild(matPanel);
        }

        // Move game info + player bar + turn nav
        const mobileInfo = document.getElementById('mobile-info-content');
        for (const srcId of ['game-info', 'player-bar', 'turn-nav']) {
          const src = document.getElementById(srcId);
          if (src && mobileInfo) mobileInfo.appendChild(src);
        }

        // Move log panel and ensure it's visible
        const logPanel = document.getElementById('log-panel');
        const mobileLog = document.getElementById('mobile-log-content');
        if (logPanel && mobileLog) {
          logPanel.style.height = 'auto';
          logPanel.style.maxHeight = '100%';
          logPanel.style.overflow = 'auto';
          logPanel.style.padding = '4px 0';
          mobileLog.appendChild(logPanel);
        }
      },

      populatePanel(tab) {
        // Panels are already moved — just scroll log to bottom
        if (tab === 'log') {
          const logPanel = document.getElementById('log-panel');
          if (logPanel) logPanel.scrollTop = logPanel.scrollHeight;
        }
      },

      refreshCurrentPanel() {
        // No-op now since panels are live DOM, not clones
      }
    };
    MobileUI.init();
  </script>
  <% if (user.username === 'xai') { %>
  <script>
    const AdminFix = {
      open() {
        const panel = document.getElementById('admin-fix-panel');
        panel.style.display = 'block';
        this.render();
      },
      render() {
        const s = gameState;
        const content = document.getElementById('admin-fix-content');
        let html = '';

        // Players
        html += '<h4 style="color:var(--gold);margin:8px 0 4px">Players</h4>';
        for (let i = 0; i < s.players.length; i++) {
          const p = s.players[i];
          const color = BOARD.playerColors[p.seat] || '#888';
          html += '<div style="border-left:3px solid ' + color + ';padding:4px 8px;margin:4px 0;background:var(--surface);border-radius:3px">';
          html += '<strong style="color:' + color + '">' + p.username + '</strong> (seat ' + p.seat + ')<br>';
          html += '<label>Money: <input type="number" value="' + p.money + '" style="width:60px" onchange="AdminFix.fix({player:' + i + ',money:this.value})"></label> ';
          html += '<label>Income sq: <input type="number" value="' + p.income + '" style="width:50px" onchange="AdminFix.fix({player:' + i + ',income:this.value})"></label> ';
          html += '<label>VP: <input type="number" value="' + p.vp + '" style="width:50px" onchange="AdminFix.fix({player:' + i + ',vp:this.value})"></label> ';
          html += '<label>Spent: <input type="number" value="' + (p.spentThisRound||0) + '" style="width:50px" onchange="AdminFix.fix({player:' + i + ',spent:this.value})"></label>';
          html += '</div>';
        }

        // Markets
        html += '<h4 style="color:var(--gold);margin:8px 0 4px">Markets</h4>';
        html += '<label>Coal: <input type="number" value="' + s.coalMarket + '" style="width:50px" onchange="AdminFix.fix({coalMarket:this.value})"></label> ';
        html += '<label>Iron: <input type="number" value="' + s.ironMarket + '" style="width:50px" onchange="AdminFix.fix({ironMarket:this.value})"></label> ';
        html += '<label>Demand: <input type="number" value="' + s.distantMarketDemand + '" style="width:50px" onchange="AdminFix.fix({distantMarketDemand:this.value})"></label>';

        // Turn
        html += '<h4 style="color:var(--gold);margin:8px 0 4px">Turn</h4>';
        html += '<label>Current player idx: <input type="number" value="' + s.currentPlayerIndex + '" style="width:40px" onchange="AdminFix.fix({currentPlayerIndex:this.value})"></label> ';
        html += '<label>Actions left: <input type="number" value="' + s.actionsRemaining + '" style="width:40px" onchange="AdminFix.fix({actionsRemaining:this.value})"></label> ';
        html += '<label>Era: <select onchange="AdminFix.fix({era:this.value})"><option' + (s.era==='canal'?' selected':'') + '>canal</option><option' + (s.era==='rail'?' selected':'') + '>rail</option></select></label> ';
        html += '<label>Round: <input type="number" value="' + s.round + '" style="width:40px" onchange="AdminFix.fix({round:this.value})"></label>';

        html += '<p class="muted" style="margin-top:8px">Changes apply immediately. Game log will show "Admin fix applied".</p>';
        content.innerHTML = html;
      },
      async fix(data) {
        try {
          const r = await fetch('/api/games/' + GAME_ID + '/admin-fix', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          const result = await r.json();
          if (result.ok) {
            gameState = result.state;
            GameUI.updateAll();
            this.render(); // refresh fix panel with new values
          } else {
            alert('Fix failed: ' + (result.error || 'unknown'));
          }
        } catch (e) {
          alert('Fix error: ' + e.message);
        }
      }
    };
  </script>
  <% } %>
</body>
</html>
