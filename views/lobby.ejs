<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Brass: Lancashire - Lobby</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <a href="/lobby" class="nav-brand">Brass: Lancashire</a>
    <div class="nav-links">
      <a href="/lobby" class="nav-link">Lobby</a>
      <a href="/wiki" class="nav-link">Wiki</a>
      <a href="/profile" class="nav-link">Stats</a>
      <a href="/account" class="nav-user"><%= user.username %></a>
      <form method="POST" action="/logout" style="display:inline">
        <button type="submit" class="btn btn-sm">Logout</button>
      </form>
    </div>
  </nav>
  <main class="container">
    <div class="lobby-layout">
      <div style="flex:1">
        <h2>My Games</h2>

        <div class="lobby-quick">
          <form method="POST" action="/games/quick" style="display:inline">
            <input type="hidden" name="numBots" value="1">
            <button type="submit" class="btn btn-primary">Quick 2P (1 bot)</button>
          </form>
          <form method="POST" action="/games/quick" style="display:inline">
            <input type="hidden" name="numBots" value="2">
            <button type="submit" class="btn btn-primary">Quick 3P (2 bots)</button>
          </form>
          <form method="POST" action="/games/quick" style="display:inline">
            <input type="hidden" name="numBots" value="3">
            <button type="submit" class="btn btn-primary">Quick 4P (3 bots)</button>
          </form>
        </div>

        <div class="lobby-create">
          <h3>Create New Game</h3>
          <form method="POST" action="/games/create" class="create-form">
            <div class="form-group">
              <label>Game Name</label>
              <input type="text" name="name" placeholder="My Game" required>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Players</label>
                <select name="numPlayers">
                  <option value="2">2 Players</option>
                  <option value="3">3 Players</option>
                  <option value="4" selected>4 Players</option>
                </select>
              </div>
              <div class="form-group">
                <label>AI Bots</label>
                <select name="numBots">
                  <option value="0">No bots</option>
                  <option value="1">1 bot</option>
                  <option value="2">2 bots</option>
                  <option value="3">3 bots</option>
                </select>
              </div>
            </div>
            <button type="submit" class="btn btn-primary">Create Game</button>
          </form>
        </div>

        <%
          const activeGames = games.filter(g => g.status === 'active');
          const waitingGames = games.filter(g => g.status === 'waiting');
          const finishedGames = games.filter(g => g.status === 'finished');
        %>

        <div class="lobby-games">
          <% if (games.length === 0) { %>
            <p class="muted">No active games. Start one!</p>
          <% } else { %>

          <!-- Filter tabs -->
          <div class="lobby-filter-tabs">
            <button class="lobby-filter-btn active" onclick="lobbyFilter('all')">All (<%= games.length %>)</button>
            <button class="lobby-filter-btn" onclick="lobbyFilter('active')">Active (<%= activeGames.length %>)</button>
            <button class="lobby-filter-btn" onclick="lobbyFilter('waiting')">Waiting (<%= waitingGames.length %>)</button>
            <button class="lobby-filter-btn" onclick="lobbyFilter('finished')">Finished (<%= finishedGames.length %>)</button>
          </div>

          <% for (const section of [{key:'active', label:'Active Games', list:activeGames}, {key:'waiting', label:'Waiting', list:waitingGames}, {key:'finished', label:'Finished', list:finishedGames}]) { %>
            <% if (section.list.length > 0) { %>
            <div class="lobby-section" data-section="<%= section.key %>">
              <h3 class="lobby-section-header" onclick="toggleLobbySection(this)">
                <%= section.label %> (<%= section.list.length %>)
                <span class="collapse-arrow">&#9660;</span>
              </h3>
              <div class="lobby-section-body">
              <% for (const game of section.list) { %>
                <div class="game-row">
                  <div class="game-card">
                    <div class="game-info">
                      <strong><%= game.name %></strong>
                      <span class="badge badge-<%= game.status %>"><%= game.status %></span>
                      <span class="muted"><%= game.player_count %>/<%= game.num_players %></span>
                      <% if (game.gameAppVersion) { %>
                        <span class="badge badge-version<%= game.compatible ? '' : ' badge-incompatible' %>">v<%= game.gameAppVersion %></span>
                      <% } %>
                    </div>
                    <div style="font-size:10px;margin-top:2px;display:flex;gap:6px;flex-wrap:wrap">
                      <% for (const p of game.player_names) { %>
                        <span style="color:<%= p.isBot ? 'var(--text-muted)' : '#fff' %>"><%= p.name %><%= p.isBot ? ' (Bot)' : '' %></span>
                      <% } %>
                    </div>
                    <div class="game-actions">
                      <% if (!game.compatible && game.status === 'active') { %>
                        <span class="muted" style="color: var(--accent)">Incompatible version</span>
                      <% } else if (game.status === 'active') { %>
                        <a href="/games/<%= game.id %>" class="btn btn-primary">Play</a>
                      <% } else if (game.status === 'waiting' && game.is_invited) { %>
                        <form method="POST" action="/games/<%= game.id %>/accept-invite" style="display:inline">
                          <button type="submit" class="btn btn-primary">Join</button>
                        </form>
                      <% } else if (game.status === 'waiting' && game.is_creator) { %>
                        <% if (game.player_count >= game.num_players) { %>
                          <form method="POST" action="/games/<%= game.id %>/start" style="display:inline">
                            <button type="submit" class="btn btn-primary">Start</button>
                          </form>
                        <% } else { %>
                          <form method="POST" action="/games/<%= game.id %>/add-bot" style="display:inline;gap:2px">
                            <select name="tier" style="font-size:9px;padding:1px 3px">
                              <option value="pro">Pro</option>
                              <option value="average" selected>Average</option>
                              <option value="noob">Noob</option>
                            </select>
                            <button type="submit" class="btn btn-sm">+ Bot</button>
                          </form>
                        <% } %>
                      <% } else if (game.status === 'waiting') { %>
                        <span class="muted">Waiting...</span>
                      <% } else if (game.status === 'finished') { %>
                        <a href="/games/<%= game.id %>" class="btn btn-sm">Review</a>
                        <span class="badge badge-finished">finished</span>
                      <% } %>
                      <% if (isAdmin && !game.is_member && (game.status === 'active' || game.status === 'finished')) { %>
                        <a href="/games/<%= game.id %>" class="btn btn-sm">Observe</a>
                      <% } %>
                    </div>
                    <% if (game.status === 'waiting' && game.is_creator) { %>
                    <div style="margin-top:4px;display:flex;gap:4px;align-items:center;font-size:10px">
                      <form method="POST" action="/games/<%= game.id %>/invite" style="display:flex;gap:4px;align-items:center">
                        <input type="text" name="username" placeholder="Invite user..." style="width:100px;padding:2px 4px;font-size:10px">
                        <button type="submit" class="btn btn-sm">Invite</button>
                      </form>
                      <% if (game.invited_names && game.invited_names.length > 0) { %>
                        <span class="muted">Invited: <%= game.invited_names.join(', ') %></span>
                      <% } %>
                    </div>
                    <% } %>
                  </div>
                  <% if (game.is_creator) { %>
                  <form method="POST" action="/games/<%= game.id %>/delete" onsubmit="return confirm('Delete this game?')">
                    <button type="submit" class="game-delete-btn" title="Delete game">🗑</button>
                  </form>
                  <% } %>
                </div>
              <% } %>
              </div>
            </div>
            <% } %>
          <% } %>
          <% } %>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lobby-sidebar">
        <div class="panel-section" style="margin-bottom:12px">
          <h4 style="color:var(--gold);margin-bottom:8px">System</h4>
          <div class="info-row">Total games: <%= totalGames %></div>
          <div class="info-row">Players: <%= totalPlayers %></div>
        </div>

        <div class="panel-section" style="margin-bottom:12px">
          <h4 style="color:var(--gold);margin-bottom:8px">Players</h4>
          <% for (const u of userList) { %>
            <div class="info-row" style="display:flex;justify-content:space-between;align-items:center">
              <span<%= u === user.username ? ' style="font-weight:bold"' : '' %>><%= u %></span>
              <a href="/profile/<%= u %>" class="muted" style="font-size:9px">stats</a>
            </div>
          <% } %>
        </div>

        <% if (isAdmin) { %>
        <div class="panel-section">
          <h4 style="color:var(--gold);margin-bottom:8px">Admin: Create User</h4>
          <form method="POST" action="/admin/create-user">
            <div class="form-group">
              <input type="text" name="username" placeholder="Username" required minlength="3" maxlength="20" style="width:100%">
            </div>
            <button type="submit" class="btn btn-primary btn-sm">Create User</button>
          </form>
          <p class="muted" style="margin-top:6px;font-size:10px">User will set their password on first login.</p>
        </div>

        <div class="panel-section" style="margin-top:12px">
          <h4 style="color:var(--gold);margin-bottom:8px">Bot Training</h4>
          <div style="display:flex;gap:4px;flex-wrap:wrap">
            <form method="POST" action="/admin/toggle-training">
              <input type="hidden" name="gamesPerBatch" value="3">
              <input type="hidden" name="intervalMs" value="10000">
              <button type="submit" class="btn btn-sm" style="background:<%= trainingStatus.active ? '#e74c3c' : '#27ae60' %>">
                <%= trainingStatus.active ? 'Stop' : 'Train' %>
              </button>
            </form>
            <form method="POST" action="/admin/run-pipeline" onsubmit="return confirm('Run full pipeline? (2000 games, may take a few minutes)')">
              <button type="submit" class="btn btn-sm" style="background:#3498db">Pipeline</button>
            </form>
            <form method="POST" action="/admin/reset-training" onsubmit="return confirm('Reset all training data?')">
              <button type="submit" class="btn btn-sm" style="color:var(--accent)">Reset</button>
            </form>
          </div>
          <div style="margin-top:8px;font-size:10px">
            <div>Games played: <strong><%= trainingStatus.totalGames || 0 %></strong></div>
            <% if (trainingStats.tiers) { %>
            <div style="margin-top:4px">
              <div style="color:#27ae60">Pro: <%= trainingStats.tiers.pro || 'TBD' %></div>
              <div style="color:#f39c12">Avg: <%= trainingStats.tiers.average || 'TBD' %></div>
              <div style="color:#e74c3c">Noob: <%= trainingStats.tiers.noob || 'TBD' %></div>
            </div>
            <% } %>
            <% if (trainingStats.rankings && Object.keys(trainingStats.rankings).length > 0) { %>
            <table style="margin-top:6px;font-size:9px;width:100%;border-collapse:collapse">
              <tr style="border-bottom:1px solid #555"><th style="text-align:left">Bot</th><th>W%</th><th>Avg</th><th>G</th></tr>
              <% const sortedBots = Object.entries(trainingStats.rankings).sort((a,b) => (b[1].winRate||0) - (a[1].winRate||0)); %>
              <% for (const [name, s] of sortedBots) { %>
              <tr><td style="text-align:left"><%= name.replace('_',' ') %></td><td style="text-align:center"><%= s.winRate || 0 %>%</td><td style="text-align:center"><%= s.avgVP || 0 %></td><td style="text-align:center"><%= s.games || 0 %></td></tr>
              <% } %>
            </table>
            <% } %>
            <% if (trainingStats.lastUpdate) { %>
            <div class="muted" style="margin-top:4px;font-size:8px">Last: <%= new Date(trainingStats.lastUpdate).toLocaleTimeString() %></div>
            <% } %>
          </div>
        </div>
        <% } %>
      </div>
    </div>

    <p class="muted" style="margin-top: 24px; text-align: center">Brass: Lancashire v<%= appVersion %></p>
  </main>
  <script>
    if (/Android|iPhone|iPad|iPod|webOS|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)
        || (window.innerWidth <= 768 && 'ontouchstart' in window)) {
      document.body.classList.add('is-mobile');
    }

    function lobbyFilter(filter) {
      document.querySelectorAll('.lobby-filter-btn').forEach(btn => {
        btn.classList.toggle('active', btn.textContent.toLowerCase().startsWith(filter));
      });
      document.querySelectorAll('.lobby-section').forEach(sec => {
        if (filter === 'all') {
          sec.style.display = '';
        } else {
          sec.style.display = sec.dataset.section === filter ? '' : 'none';
        }
      });
    }

    function toggleLobbySection(header) {
      const body = header.nextElementSibling;
      const arrow = header.querySelector('.collapse-arrow');
      if (body.style.display === 'none') {
        body.style.display = '';
        arrow.innerHTML = '&#9660;';
      } else {
        body.style.display = 'none';
        arrow.innerHTML = '&#9654;';
      }
    }
  </script>
</body>
</html>
